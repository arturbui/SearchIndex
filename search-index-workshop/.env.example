# Copy to .env (docker compose + the TS scripts both read these)
POSTGRES_USER=workshop
POSTGRES_PASSWORD=workshop
POSTGRES_DB=knuspr
POSTGRES_PORT=5432
POSTGRES_HOST=localhost

# pgAdmin login (http://localhost:5050) — demo only, `docker compose --profile demo up -d`
PGADMIN_EMAIL=admin@workshop.local
PGADMIN_PASSWORD=workshop
PGADMIN_PORT=5050

# How many products to generate by default
PRODUCT_COUNT=20000
